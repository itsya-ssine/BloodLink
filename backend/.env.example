APP_ENV=development
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=bloodlink
DB_USER=postgres
DB_PASS=postgres

# Browser-safe frontend runtime vars
PUBLIC_API_BASE_URL=http://localhost:8080/api

# Session auth
SESSION_NAME=bloodlink_session
SESSION_SECURE_COOKIE=false
SESSION_SAMESITE=Lax

# Optional app/mail metadata used in auth flows
APP_URL=http://localhost:8080
MAIL_FROM_ADDRESS=no-reply@bloodlink.local
MAIL_FROM_NAME=BloodLink
MAIL_LOG_ONLY=false

# Comma-separated origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
